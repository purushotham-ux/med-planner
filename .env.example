# ========================================
# MedRep Territory Planner - Environment
# ========================================

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/medrep_planner?schema=public"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-this"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV="development"
CORS_ORIGIN="http://localhost:5173"

# Default Admin User (for seed)
ADMIN_EMAIL="admin@medrep.local"
ADMIN_PASSWORD="admin123"
ADMIN_NAME="Medical Rep"

# Nominatim Geocoding (no API key needed)
NOMINATIM_BASE_URL="https://nominatim.openstreetmap.org"
NOMINATIM_USER_AGENT="MedRepTerritoryPlanner/1.0"

# OSRM Routing (no API key needed)
OSRM_BASE_URL="https://router.project-osrm.org"
